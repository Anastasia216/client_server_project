<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="500.0" prefWidth="700.0" style="-fx-background-color: #ffffff;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.frontend.AdminPage">
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="60.0" spacing="20.0" style="-fx-background-color: #212529; -fx-padding: 0 20 0 20;">
            <children>
                <Label text="ADMIN DASHBOARD" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="20.0" />
                    </font>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="exitButton" onAction="#handleExit" prefHeight="35.0" prefWidth="120.0" style="-fx-background-color: #dc3545; -fx-text-fill: white; -fx-background-radius: 6; -fx-cursor: hand;" text="EXIT TO CHAT">
                    <font>
                        <Font name="System Bold" size="12.0" />
                    </font>
                </Button>
            </children>
        </HBox>
    </top>
    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE">
            <tabs>
                <Tab text="Statistics">
                    <content>
                        <AnchorPane>
                            <VBox alignment="CENTER" prefHeight="370.0" prefWidth="600.0" spacing="20.0" AnchorPane.bottomAnchor="25.0" AnchorPane.leftAnchor="25.0" AnchorPane.rightAnchor="25.0" AnchorPane.topAnchor="25.0">
                                <children>
                                    <Label fx:id="onlineCountLabel" maxWidth="1.7976931348623157E308" prefHeight="60.0" style="-fx-background-color: #f8f9fa; -fx-border-color: #dee2e6; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 0 0 0 20;" text="Online Users: Loading..." textFill="#495057">
                                        <font><Font name="System Bold" size="18.0" /></font>
                                    </Label>
                                    <Label fx:id="totalUsersLabel" maxWidth="1.7976931348623157E308" prefHeight="60.0" style="-fx-background-color: #f8f9fa; -fx-border-color: #dee2e6; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 0 0 0 20;" text="Total Users: Loading..." textFill="#495057">
                                        <font><Font name="System Bold" size="18.0" /></font>
                                    </Label>
                                    <Label fx:id="totalMessagesLabel" maxWidth="1.7976931348623157E308" prefHeight="60.0" style="-fx-background-color: #f8f9fa; -fx-border-color: #dee2e6; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 0 0 0 20;" text="Total Messages: Loading..." textFill="#495057">
                                        <font><Font name="System Bold" size="18.0" /></font>
                                    </Label>
                                </children>
                            </VBox>
                        </AnchorPane>
                    </content>
                </Tab>
                <Tab text="User Management">
                    <content>
                        <BorderPane>
                            <center>
                                <TableView fx:id="usersTable" style="-fx-selection-bar: #e9ecef;">
                                    <columns>
                                        <TableColumn fx:id="colId" prefWidth="60.0" text="ID" />
                                        <TableColumn fx:id="colStatus" prefWidth="100.0" text="Status" />
                                        <TableColumn fx:id="colRole" prefWidth="100.0" text="Role" />
                                        <TableColumn fx:id="colBlock" prefWidth="100.0" text="Block status" />
                                        <TableColumn fx:id="colActions" prefWidth="180.0" text="Actions" />
                                    </columns>
                                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                                    <BorderPane.margin><Insets bottom="10.0" left="15.0" right="15.0" top="15.0" /></BorderPane.margin>
                                </TableView>
                            </center>
                        </BorderPane>
                    </content>
                </Tab>
                <Tab text="Server Logs">
                    <content>
                        <BorderPane>
                            <top>
                                <HBox alignment="CENTER_RIGHT" prefHeight="55.0" spacing="15.0" style="-fx-background-color: #f8f9fa; -fx-border-color: #dee2e6; -fx-border-width: 0 0 1 0;">
                                    <children>
                                        <Button fx:id="clearLogButton" onAction="#handleClearLogs" prefHeight="32.0" style="-fx-background-color: transparent; -fx-border-color: #6c757d; -fx-text-fill: #495057; -fx-border-radius: 5; -fx-cursor: hand;" text="Clear Screen" />
                                    </children>
                                    <padding><Insets left="15.0" right="15.0" /></padding>
                                </HBox>
                            </top>
                            <center>
                                <TextArea fx:id="serverLogsArea" editable="false" style="-fx-control-inner-background: #1e1e1e; -fx-font-family: 'Consolas', monospace; -fx-text-fill: #20c997; -fx-font-size: 13px;" text="[SERVER] Monitoring active...&#10;">
                                    <BorderPane.margin><Insets bottom="10.0" left="10.0" right="10.0" top="10.0" /></BorderPane.margin>
                                </TextArea>
                            </center>
                        </BorderPane>
                    </content>
                </Tab>
            </tabs>
        </TabPane>
    </center>
</BorderPane>