<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox maxHeight="350.0" maxWidth="360.0" spacing="15.0" style="-fx-background-color: #ffffff; -fx-background-radius: 12;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.frontend.UserInfoController">
    <padding>
        <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
    </padding>
    <children>
        <Label text="My Profile" textFill="#212529"><font><Font name="System Bold" size="22.0" /></font></Label>

        <VBox spacing="5.0">
            <children>
                <Label text="Username" textFill="#6c757d" />
                <TextField fx:id="usernameField" editable="false" prefHeight="40.0" style="-fx-background-radius: 8; -fx-border-color: #ced4da; -fx-background-color: #e9ecef; -fx-text-fill: #495057;" />
            </children>
        </VBox>

        <VBox spacing="5.0">
            <children>
                <Label text="Phone Number" textFill="#6c757d" />
                <TextField fx:id="phoneField" editable="false" prefHeight="40.0" style="-fx-background-radius: 8; -fx-border-color: #ced4da; -fx-background-color: #e9ecef; -fx-text-fill: #495057;" />
            </children>
        </VBox>

        <Label fx:id="errorLabel" textFill="#ef4444" wrapText="true"><font><Font size="13.0" /></font></Label>

        <HBox alignment="CENTER_RIGHT" spacing="15.0">
            <children>
                <Button fx:id="cancelButton" text="Cancel" style="-fx-background-color: transparent; -fx-text-fill: #6c757d; -fx-cursor: hand;" />
                <Button fx:id="saveButton" text="Edit Profile" prefHeight="38.0" style="-fx-background-color: #10B981; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-weight: bold; -fx-padding: 0 20 0 20;" />
            </children>
        </HBox>
    </children>
</VBox>