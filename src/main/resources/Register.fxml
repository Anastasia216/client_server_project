<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: linear-gradient(to bottom right, #f4f7f6, #e0eafc);" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.frontend.RegisterController">
    <children>
        <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" prefHeight="550.0" prefWidth="420.0" spacing="15.0" style="-fx-background-color: #ffffff; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 15, 0, 0, 5);">
            <padding>
                <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
            </padding>

            <Label text="Register" textFill="#333333">
                <font>
                    <Font name="System Bold" size="28.0" />
                </font>
                <VBox.margin>
                    <Insets bottom="5.0" />
                </VBox.margin>
            </Label>

            <TextField fx:id="regUsernameField" prefHeight="45.0" promptText="Choose Username" style="-fx-background-radius: 8; -fx-border-color: #dcdcdc; -fx-border-radius: 8; -fx-background-color: #fafafa;">
                <font>
                    <Font size="14.0" />
                </font>
            </TextField>

            <TextField fx:id="regPhoneField" prefHeight="45.0" promptText="Your Phone Number" style="-fx-background-radius: 8; -fx-border-color: #dcdcdc; -fx-border-radius: 8; -fx-background-color: #fafafa;">
                <font>
                    <Font size="14.0" />
                </font>
            </TextField>

            <PasswordField fx:id="regPasswordField" prefHeight="45.0" promptText="Password" style="-fx-background-radius: 8; -fx-border-color: #dcdcdc; -fx-border-radius: 8; -fx-background-color: #fafafa;">
                <font>
                    <Font size="14.0" />
                </font>
            </PasswordField>

            <PasswordField fx:id="confirmPasswordField" prefHeight="45.0" promptText="Confirm Password" style="-fx-background-radius: 8; -fx-border-color: #dcdcdc; -fx-border-radius: 8; -fx-background-color: #fafafa;">
                <font>
                    <Font size="14.0" />
                </font>
            </PasswordField>

            <Button onAction="#handleRegister" prefHeight="45.0" prefWidth="Infinity" style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text="Register">
                <font>
                    <Font size="15.0" />
                </font>
                <VBox.margin>
                    <Insets top="10.0" />
                </VBox.margin>
            </Button>

            <Hyperlink onAction="#switchToLogin" style="-fx-border-color: transparent;" text="Already have an account? Sign in" textFill="#007bff">
                <font>
                    <Font size="13.0" />
                </font>
            </Hyperlink>

            <Label fx:id="errorLabel" textFill="#dc3545" wrapText="true" />
        </VBox>
    </children>
</StackPane>